            },
            {
              "name": "mensaje",
              "value": "={{ 'Genera un informe diario ejecutivo en 3 párrafos. Tareas pendientes: ' + $json.total + '. Por prioridad: ' + $json.porPrioridadStr + '. Incluye una recomendación de acción.' }}"
            }
          ]
        },
        "options": {}
      },
