    {
      "parameters": {
        "jsCode": "const entrada = {\n  fecha: new Date().toISOString(),\n  informe: $json.respuesta,\n  stats: {\n    total: $('Code Agrupar por Prioridad').item.json.total,\n    porPrioridad: $('Code Agrupar por Prioridad').item.json.porPrioridad\n  }\n};\n\nreturn [{ json: { guardado: true, fecha: entrada.fecha, informe: entrada.informe, stats: entrada.stats } }];"
      },
