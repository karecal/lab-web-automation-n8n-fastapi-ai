    {
      "parameters": {
        "jsCode": "const tareas = $input.all().map(i => i.json);\nconst porPrioridad = tareas.reduce((acc, t) => {\n  acc[t.prioridad] = (acc[t.prioridad] || 0) + 1;\n  return acc;\n}, {});\nreturn [{ json: { total: tareas.length, porPrioridad, porPrioridadStr: JSON.stringify(porPrioridad) } }];"
      },
